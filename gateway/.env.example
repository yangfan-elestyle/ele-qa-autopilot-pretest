# gateway (qa) 运行时配置. 生产由 compose env_file / docker secrets 注入.
# 下游内网 HTTP base (compose service name); 必填.
AUTOPILOT_URL=http://autopilot:8080
AUTOTEST_URL=http://autotesting:8080
# 允许登录的邮箱后缀.
ALLOWED_EMAIL_DOMAIN=@elestyle.jp
# 登录 cookie 存活秒数 (默认 400 天).
COOKIE_MAX_AGE=34560000
# 监听端口 (容器内; 对外经 nginx 反代).
PORT=8080
