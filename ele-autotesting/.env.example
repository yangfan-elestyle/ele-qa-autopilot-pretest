# ele-autotesting 运行时配置. 生产由 compose env_file / docker secrets 注入.
# libSQL embedded (随容器 volume /data).
DATABASE_URL=file:/data/autotesting.db
# 下游内网 HTTP (compose service / 内网域名).
AUTOPILOT_URL=http://autopilot:8080
METERSPHERE_URL=https://qa.elepay.link
# agentic-loop (ele-harness 后端) 就绪后填 compose service; 未就绪留空.
# AGENTIC_LOOP_URL=http://agentic-loop:3000
# markitdown sidecar (compose service).
MARKITDOWN_URL=http://markitdown:8080

# Confluence (服务端拉页面 HTML)
# QA_ALTASSIAN_API_KEY=
# QA_ALTASSIAN_EMAIL=
# Vision API (图像理解 / OCR)
# QA_IMAGE_RESEARCH_OPENAI_API_KEY=
# QA_IMAGE_RESEARCH_OPENAI_VISION_MODEL=gpt-4o
# QA_IMAGE_RESEARCH_GEMINI_API_KEY=
# QA_IMAGE_RESEARCH_GEMINI_VISION_MODEL=gemini-3-flash-preview

# 本地 dev 兜底 owner: 直连 (不经 gateway) 缺 X-Auth-User-Email 头时用. 生产严禁设置.
# DEV_FALLBACK_EMAIL=smoke@elestyle.jp

# 容器内监听端口 (仅 compose 内网可达, 不 publish).
PORT=8080
