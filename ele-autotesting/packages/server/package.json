{
  "name": "@prompt-optimizer/server",
  "version": "1.0.0",
  "private": true,
  "description": "Hono Worker for Prompt Optimizer on Cloudflare",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "node -e \"require('fs').mkdirSync('../web/dist',{recursive:true})\" && wrangler dev --env-file ../../.env",
    "deploy": "wrangler deploy",
    "build": "wrangler deploy --dry-run --outdir dist",
    "tail": "wrangler tail",
    "smoke": "node scripts/smoke.mjs",
    "clean": "rm -rf dist .wrangler"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@cloudflare/containers": "^0.3.4",
    "@google/genai": "^2.4.0",
    "@resvg/resvg-wasm": "^2.6.2",
    "hono": "^4.9.6",
    "openai": "^6.38.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20251101.0",
    "wrangler": "^4.92.0"
  }
}
