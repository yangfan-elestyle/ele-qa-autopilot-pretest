{
  "name": "@prompt-optimizer/server",
  "version": "1.0.0",
  "private": true,
  "description": "Hono server for Prompt Optimizer (Node/Docker)",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --target=node24 --outfile=dist/server.mjs --external:@libsql/client --external:@resvg/resvg-js --banner:js=\"import{createRequire}from'module';const require=createRequire(import.meta.url);\"",
    "start": "node dist/server.mjs",
    "smoke": "node scripts/smoke.mjs",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@hono/node-server": "^1.14.0",
    "@libsql/client": "^0.17.4",
    "@resvg/resvg-js": "^2.6.2",
    "hono": "^4.9.6",
    "openai": "^6.38.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "esbuild": "^0.25.0"
  }
}
