{
  "name": "prompt-optimizer",
  "version": "1.5.2",
  "private": true,
  "packageManager": "pnpm@10.6.1",
  "engines": {
    "node": ">=24.0.0",
    "npm": "请使用pnpm代替npm",
    "yarn": "请使用pnpm代替yarn"
  },
  "scripts": {
    "build": "npm-run-all build:core build:ui build:web",
    "build:core": "pnpm -F @prompt-optimizer/core build",
    "build:ui": "pnpm -F @prompt-optimizer/ui build",
    "build:web": "pnpm -F @prompt-optimizer/web build",
    "build:cf": "npm-run-all build:core build:ui build:web",
    "deploy": "pnpm run build:cf && pnpm -F @prompt-optimizer/server run deploy",
    "dev": "npm-run-all clean:dist build:core build:ui dev:parallel",
    "dev:fresh": "npm-run-all clean pnpm-install dev",
    "dev:parallel": "concurrently -k -p \"[{name}]\" -n \"UI,WEB,WORKER\" \"pnpm -F @prompt-optimizer/ui build --watch\" \"pnpm -F @prompt-optimizer/web dev\" \"pnpm -F @prompt-optimizer/server dev\"",
    "clean": "npm-run-all clean:dist clean:vite",
    "clean:dist": "rimraf packages/core/dist packages/ui/dist packages/web/dist packages/server/dist packages/server/.wrangler",
    "clean:vite": "rimraf packages/core/node_modules/.vite packages/ui/node_modules/.vite packages/web/node_modules/.vite",
    "pnpm-install": "pnpm install"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "lodash-unified": "^1.0.3",
    "npm-run-all": "^4.1.5",
    "rimraf": "^4.4.1",
    "typescript": "^5.8.2"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.1",
    "@floating-ui/core": "^1.6.9",
    "@floating-ui/dom": "^1.6.13",
    "@floating-ui/utils": "^0.2.9",
    "@popperjs/core": "^2.11.8",
    "@vue/reactivity": "^3.5.13",
    "@vue/runtime-core": "^3.5.13",
    "@vue/runtime-dom": "^3.5.13",
    "@vue/shared": "^3.5.13",
    "@vueuse/core": "^12.7.0",
    "@vueuse/shared": "^12.7.0",
    "async-validator": "^4.2.5",
    "dayjs": "^1.11.13",
    "electron-to-chromium": "^1.5.177",
    "lodash-es": "^4.17.21",
    "memoize-one": "^6.0.0",
    "normalize-wheel-es": "^1.2.0"
  },
  "keywords": [],
  "author": "",
  "license": "ISC"
}
