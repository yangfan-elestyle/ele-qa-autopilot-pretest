# deploy/.env — compose 编排配置 (拷成 deploy/.env, 勿提交). docker compose 自动加载同目录 .env.

# --- 对外入口 (仅 nginx publish) ---
BIND_ADDR=0.0.0.0
HTTP_PORT=80

# --- 身份 ---
ALLOWED_EMAIL_DOMAIN=@elestyle.jp
COOKIE_MAX_AGE=34560000

# --- MinIO (S3 兼容对象存储) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-in-prod
S3_REGION=us-east-1
SCREENSHOTS_BUCKET=ele-autopilot-screenshots
RELEASES_BUCKET=ele-autopilot-releases

# --- 上游 ---
METERSPHERE_URL=https://bi.elepay.link
# agentic-loop (ele-harness 后端) 联合迁移后填; 未就绪留空.
AGENTIC_LOOP_URL=

# --- autotesting 可选 LLM/Confluence 凭据 (不填则相关功能禁用) ---
QA_ALTASSIAN_API_KEY=
QA_ALTASSIAN_EMAIL=
QA_IMAGE_RESEARCH_OPENAI_API_KEY=
QA_IMAGE_RESEARCH_OPENAI_VISION_MODEL=gpt-4o
QA_IMAGE_RESEARCH_GEMINI_API_KEY=
QA_IMAGE_RESEARCH_GEMINI_VISION_MODEL=gemini-3-flash-preview

# --- 镜像 (生产指向 GHCR; 本地构建留默认 :local) ---
# GATEWAY_IMAGE=ghcr.io/<owner>/ele-qa-gateway:v1.28.10
# AUTOPILOT_IMAGE=ghcr.io/<owner>/ele-qa-autopilot:v1.28.10
# AUTOTEST_IMAGE=ghcr.io/<owner>/ele-qa-autotesting:v1.28.10
# MARKITDOWN_IMAGE=ghcr.io/<owner>/ele-qa-markitdown:v1.28.10
