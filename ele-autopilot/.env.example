# ele-autopilot 运行时配置. 生产由 compose env_file / docker secrets 注入.
# libSQL embedded (随容器 volume /data); D1 → 此.
DATABASE_URL=file:/data/autopilot.db
# 对象存储 (MinIO / S3 兼容); R2 → 此. 内网 compose service.
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
SCREENSHOTS_BUCKET=ele-autopilot-screenshots
RELEASES_BUCKET=ele-autopilot-releases
# 高敏感路由 email 域校验.
ALLOWED_EMAIL_DOMAIN=@elestyle.jp
# 容器内监听端口 (仅 compose 内网可达, 不 publish).
PORT=8080
