# ele-autopilot 运行时配置. 生产由 compose env_file / docker secrets 注入.
# libSQL embedded (随容器 volume /data).
DATABASE_URL=file:/data/autopilot.db
# 截图落盘目录 (随容器 volume /data); 可再生任务产物, 不用对象存储.
SCREENSHOTS_DIR=/data/screenshots
# 发布产物 (ele-autopilot-local wheel) 也不走对象存储; 镜像构建期打进 /app/releases (见 Dockerfile).
# 高敏感路由 email 域校验.
ALLOWED_EMAIL_DOMAIN=@elestyle.jp
# 容器内监听端口 (仅 compose 内网可达, 不 publish).
PORT=8080
